class Solution {
public:
    ListNode* sortList(ListNode* head) {
        if (!head || !head->next) return head;
        vector<int> nums;
        ListNode* curr = head;
        while (curr) {
            nums.push_back(curr->val);
            curr = curr->next;
        }
        sort(nums.begin(), nums.end());
        curr = head;
        for (int i = 0; i < nums.size(); i++) {
            curr->val = nums[i];
            curr = curr->next;
        }

        return head;
    }
};
